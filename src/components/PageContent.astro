---
import type { Locale } from '../i18n';
import { getDict } from '../i18n';
import Header from './Header.astro';
import Hero from './Hero.astro';
import ScreenshotStrip from './ScreenshotStrip.astro';
import FeatureSection from './FeatureSection.astro';
import FinalCta from './FinalCta.astro';
import Footer from './Footer.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const screenshotFiles = [
  '01-month.png',
  '02-google.png',
  '03-share.png',
  '04-themes.png',
  '05-widget.png',
];
---

<Header locale={locale} />
<main>
  <Hero locale={locale} />
  <ScreenshotStrip locale={locale} />
  {
    dict.features.map((f, i) => (
      <>
        <div class="divider" />
        <FeatureSection
          number={f.number}
          title={f.title}
          body={f.body}
          alt={f.alt}
          image={`${base}/images/screenshots/${screenshotFiles[i]}`}
          reverse={i % 2 === 1}
        />
      </>
    ))
  }
  <div class="divider" />
  <FinalCta locale={locale} />
</main>
<Footer locale={locale} />
