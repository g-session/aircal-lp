---
import type { Locale } from '../i18n';
import { getDict } from '../i18n';
import StoreButtons from './StoreButtons.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="hero">
  <div class="container inner">
    <img
      class="app-icon"
      src={`${base}/images/app-icon.png`}
      alt="aircal app icon"
      width="120"
      height="120"
    />

    <h1 class="h1 wordmark">aircal</h1>

    <p class="tagline">{dict.hero.tagline}</p>
    <p class="lead description">{dict.hero.description}</p>

    <div class="cta">
      <StoreButtons locale={locale} />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(48px, 8vw, 96px) 0 clamp(40px, 7vw, 72px);
    text-align: center;
  }

  .inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .app-icon {
    width: clamp(96px, 13vw, 128px);
    height: auto;
    border-radius: 24px;
    box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.15),
      0 6px 18px -8px rgba(0, 0, 0, 0.08);
  }

  .wordmark {
    margin-top: 8px;
    font-family:
      -apple-system,
      BlinkMacSystemFont,
      "SF Pro Display",
      "SF Pro Text",
      "Helvetica Neue",
      "Inter",
      sans-serif;
  }

  .tagline {
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 16px 0 0;
    color: var(--fg);
  }

  .description {
    max-width: 540px;
    margin-top: 4px;
    color: var(--fg-muted);
  }

  .cta {
    margin-top: 24px;
  }
</style>
