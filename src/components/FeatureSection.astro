---
interface Props {
  number: string;
  title: string;
  body: string;
  image: string;
  alt: string;
  reverse?: boolean;
}

const { number, title, body, image, alt, reverse = false } = Astro.props;
---

<section class="feature">
  <div class:list={['container', 'inner', { reverse }]}>
    <div class="copy">
      <p class="number">
        <span>{number}</span>
        <span class="dash">—</span>
      </p>
      <h2 class="h2 title">{title}</h2>
      <p class="body desc">{body}</p>
    </div>
    <div class="visual">
      <img class="phone" src={image} alt={alt} loading="lazy" />
    </div>
  </div>
</section>

<style>
  .feature {
    padding: var(--gap-section) 0;
  }

  .inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: center;
  }

  @media (min-width: 900px) {
    .inner {
      grid-template-columns: 1fr 1fr;
      gap: clamp(48px, 6vw, 96px);
    }

    .inner.reverse .copy {
      order: 2;
    }

    .inner.reverse .visual {
      order: 1;
    }
  }

  .copy {
    max-width: 460px;
  }

  .number {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-en);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    margin: 0 0 20px;
  }

  .dash {
    color: var(--fg-faint);
    font-weight: 400;
  }

  .title {
    margin-bottom: 20px;
  }

  .desc {
    line-height: 1.9;
  }

  .visual {
    display: flex;
    justify-content: center;
  }

  .phone {
    width: 100%;
    max-width: 320px;
    height: auto;
    border-radius: 24px;
    box-shadow: 0 24px 60px -24px rgba(0, 0, 0, 0.18),
      0 8px 24px -12px rgba(0, 0, 0, 0.08);
  }
</style>
