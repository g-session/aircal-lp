---
import type { Locale } from '../i18n';
import { getDict } from '../i18n';
import StoreButtons from './StoreButtons.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
---

<section class="final">
  <div class="container inner">
    <h2 class="h2 title">{dict.finalCta.title}</h2>
    <StoreButtons locale={locale} />
  </div>
</section>

<style>
  .final {
    padding: var(--gap-section) 0;
    text-align: center;
  }

  .inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 36px;
  }

  .title {
    max-width: 600px;
  }
</style>
