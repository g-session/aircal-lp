---
import type { Locale } from '../i18n';
import { getDict } from '../i18n';
import Header from './Header.astro';
import Footer from './Footer.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
const sectionId = (index: number) => `section-${index + 1}`;
---

<Header locale={locale} />

<main class="contact-page">
  <div class="container">
    <header class="page-head">
      <h1 class="contact-heading">{dict.contact.heading}</h1>
      <p class="contact-subheading">{dict.contact.subheading}</p>
    </header>

    <nav class="toc" aria-label={dict.contact.tocTitle}>
      <p class="toc-title">{dict.contact.tocTitle}</p>
      <ul>
        {
          dict.contact.sections.map((s, i) => (
            <li>
              <a href={`#${sectionId(i)}`}>{s.heading}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    {
      dict.contact.sections.map((s, i) => (
        <section class="section" id={sectionId(i)}>
          <h2 class="section-heading">{s.heading}</h2>
          <p class="section-intro">{s.intro}</p>
          <ul class="items">
            {s.items.map((item) => (
              <li>
                <span class="label">{item.label}</span>
                <span class="dash">—</span>
                <a class="link" href={item.href} target="_blank" rel="noopener">
                  {item.value}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</main>

<Footer locale={locale} />

<style>
  .contact-page {
    padding: clamp(48px, 8vw, 96px) 0 clamp(56px, 9vw, 96px);
  }

  .page-head {
    margin-bottom: clamp(40px, 6vw, 64px);
  }

  .contact-heading {
    font-family:
      -apple-system,
      BlinkMacSystemFont,
      "SF Pro Display",
      "Helvetica Neue",
      "Inter",
      sans-serif;
    font-size: clamp(48px, 9vw, 88px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1;
    margin: 0;
  }

  .contact-subheading {
    font-size: clamp(16px, 1.8vw, 18px);
    color: var(--fg-muted);
    margin: 12px 0 0;
    font-weight: 500;
  }

  .toc {
    padding: 20px 24px;
    background: var(--bg-soft);
    border-radius: 12px;
    margin-bottom: clamp(48px, 7vw, 72px);
  }

  .toc-title {
    font-family: var(--font-en);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-faint);
    margin: 0 0 12px;
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .toc a {
    color: var(--fg);
    font-size: 15px;
    transition: color 0.15s ease;
  }

  .toc a::before {
    content: "•";
    color: var(--fg-faint);
    margin-right: 10px;
  }

  .toc a:hover {
    color: var(--fg-muted);
  }

  .section {
    margin-bottom: clamp(48px, 7vw, 80px);
    scroll-margin-top: 80px;
  }

  .section:last-of-type {
    margin-bottom: 0;
  }

  .section-heading {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 0 0 16px;
  }

  .section-intro {
    color: var(--fg-muted);
    margin: 0 0 20px;
    line-height: 1.85;
  }

  .items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .items li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px;
    font-size: 15px;
  }

  .items .label {
    color: var(--fg);
    min-width: 100px;
  }

  .items .dash {
    color: var(--fg-faint);
  }

  .items .link {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--fg-faint);
    transition: text-decoration-color 0.15s ease;
    word-break: break-all;
  }

  .items .link:hover {
    text-decoration-color: var(--fg);
  }
</style>
