---
import type { Locale } from '../i18n';
import { getDict } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const shots = [
  {
    src: `${base}/images/cover-left.png`,
    alt: locale === 'ja' ? 'aircal キービジュアル' : 'aircal key visual',
    eager: true,
  },
  {
    src: `${base}/images/cover-right.png`,
    alt: dict.features[0].alt,
    eager: true,
  },
  {
    src: `${base}/images/screenshots/03-share.png`,
    alt: dict.features[2].alt,
    eager: false,
  },
  {
    src: `${base}/images/screenshots/04-themes.png`,
    alt: dict.features[3].alt,
    eager: false,
  },
  {
    src: `${base}/images/screenshots/05-widget.png`,
    alt: dict.features[4].alt,
    eager: false,
  },
];
---

<section class="strip">
  <div class="track">
    {
      shots.map((s) => (
        <img
          class="phone"
          src={s.src}
          alt={s.alt}
          loading={s.eager ? 'eager' : 'lazy'}
        />
      ))
    }
  </div>
</section>

<style>
  .strip {
    padding: 0 0 clamp(40px, 7vw, 72px);
    overflow: hidden;
  }

  .track {
    display: flex;
    gap: 12px;
    padding-inline: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .track::-webkit-scrollbar {
    display: none;
  }

  .phone {
    flex: 0 0 auto;
    width: clamp(180px, 22vw, 240px);
    height: auto;
    border-radius: 24px;
    scroll-snap-align: center;
    box-shadow: 0 24px 60px -24px rgba(0, 0, 0, 0.18),
      0 8px 24px -12px rgba(0, 0, 0, 0.08);
  }

  @media (min-width: 1024px) {
    .track {
      justify-content: center;
      overflow: visible;
    }
  }
</style>
